generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            BigInt            @id @default(autoincrement())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accountId     String
  nickname      String            @unique
  password      String            @default("")
  name          String            @default("")
  mobile        String            @default("")
  emailVerified DateTime?
  role          ROLE              @default(USER)
  provider      PROVIDER          @default(CREDENTIALS)
  status        USER_STATUS       @default(ACTIVE)
  isNewUser     Boolean           @default(true)
  adminMemo     String?           // 관리자 메모 필드 추가

  comments      Comment[]
  coupons       Coupon[]
  payments      Payment[]
  points        Point[]
  posts         Post[]            @relation("AuthoredPosts")
  reviews       Review[]
  postLikes     PostLike[]
  orders        Order[]

  @@unique([accountId, provider])
}

model VerificationToken {
  userId  BigInt
  token   String
  expires DateTime

  @@unique([userId, token])
}

model Board {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String   @default("")
  slug      String   @unique
  misc      Json     @default("{}")

  posts     Post[]
}

model Post {
  id        BigInt    @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  thumbnail String    @default("")
  title     String    @default("")
  content   String    @default("")
  slug      String    @unique @default("")
  views     Int       @default(0)
  tags      String[]  @default([])
  files     Json      @default("[]")
  authorId  BigInt
  boardId   BigInt
  misc      Json      @default("{}")

  comments  Comment[]
  author    User      @relation("AuthoredPosts", fields: [authorId], references: [id])
  board     Board     @relation(fields: [boardId], references: [id])
  likes     PostLike[]

  @@index([authorId])
  @@index([boardId])
}

model PostLike {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postId    BigInt
  userId    BigInt
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Comment {
  id             BigInt    @id @default(autoincrement())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  content        String    @default("")
  authorId       BigInt
  postId         BigInt
  parentId       BigInt?
  deleted        Boolean   @default(false)
  deletedContent String    @default("삭제된 댓글입니다.")
  misc           Json      @default("{}")
  author         User      @relation(fields: [authorId], references: [id])
  parent         Comment?  @relation("CommentParent", fields: [parentId], references: [id])
  replies        Comment[] @relation("CommentParent")
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([postId])
  @@index([parentId])
}

model Log {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  content   Json     @default("{}")
}

model Product {
  id              BigInt           @id @default(autoincrement())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  title           String
  description     String?
  content         String?
  thumbnail       String?
  isPublished     Boolean          @default(false)

  productItems    ProductItem[]
}

model ProductItem {
  id              BigInt           @id @default(autoincrement())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  name            String
  originalPrice   Int
  salePrice       Int
  searchTags      String[] @default([])

  productId       BigInt
  product         Product        @relation(fields: [productId], references: [id])

  images          ProductImage[]
  orderItems      OrderItem[]
  reviews         Review[]
}

model ProductImage {
  id         BigInt   @id @default(autoincrement())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  imageOrder Int      @default(0)
  imageType  PRODUCT_IMAGE_TYPE @default(DETAIL)
  imageUrl   String

  productItemId BigInt
  productItem   ProductItem  @relation(fields: [productItemId], references: [id])
}

model Order {
  id                BigInt          @id @default(autoincrement())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  amount            Int
  status            ORDER_STATUS    @default(ACCEPT)
  shippingPrice     Int             @default(0)
  remotePrice       Int             @default(0)
  remoteArea        Boolean         @default(false)
  address           String
  logisticsProvider String
  trackingNumber    String

  orderItems       OrderItem[]

  receiverId       BigInt
  receiver         Receiver        @relation(fields: [receiverId], references: [id])

  ordererId        BigInt
  orderer          Orderer        @relation(fields: [ordererId], references: [id])

  paymentId        BigInt?         @unique
  payment          Payment?        @relation(fields: [paymentId], references: [id])

  userId           BigInt?
  user             User?           @relation(fields: [userId], references: [id])
}

model OrderItem {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quantity      Int
  originalPrice Int
  salePrice     Int
  totalAmount   Int

  orderId   BigInt
  order     Order    @relation(fields: [orderId], references: [id])

  productItemId BigInt
  productItem   ProductItem  @relation(fields: [productItemId], references: [id])
}

model Orderer {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  mobile    String
  email     String

  orders Order[]
}

model Receiver {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  mobile    String
  address   String
  postCode  String

  orders Order[]
}

model Payment {
  id               BigInt          @id @default(autoincrement())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  amount           Int
  status           PAYMENT_STATUS
  method           String
  isRefunded       Boolean         @default(false)
  refundedAt       DateTime?
  refundAmount     Int?
  refundReason     String?
  merchantUid      String?         @unique
  pgProvider       String?
  receiptUrl       String?
  userId           BigInt
  paymentKey       String?         @unique
  isTest           Boolean         @default(false)
  user             User            @relation(fields: [userId], references: [id])
  refunds          Refund[]

  orderId          BigInt?
  order            Order?

  @@index([userId])
  @@index([merchantUid])
  @@index([paymentKey])
}

model Coupon {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  expiresAt DateTime
  code      String   @unique
  discount  Int
  isPercent Boolean
  isUsed    Boolean  @default(false)
  userId    BigInt?
  user      User?    @relation(fields: [userId], references: [id])
}

model Point {
  id          BigInt   @id @default(autoincrement())
  createdAt   DateTime @default(now())
  amount      Int
  description String
  userId      BigInt
  user        User     @relation(fields: [userId], references: [id])
}

model Review {
  id               BigInt          @id @default(autoincrement())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  title            String
  content          String
  views            Int             @default(0)
  userId           BigInt?         // 가상 리뷰의 경우 null 가능
  isBest           Boolean         @default(false)
  isVirtual        Boolean         @default(false) // 가상 리뷰 여부
  virtualAuthor    String?         // 가상 리뷰 작성자 이름
  user             User?           @relation(fields: [userId], references: [id])
  thumbnail        String?

  productItemId    BigInt?
  productItem      ProductItem?   @relation(fields: [productItemId], references: [id])

  @@index([userId])
}

model PaymentSession {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  expiresAt DateTime
  orderId   String   @unique
  amount    Int
  orderName String
  userId    BigInt?
  status    String   @default("PENDING")

  @@index([orderId])
  @@index([expiresAt])
  @@index([userId])
}

model Refund {
  id                BigInt        @id @default(autoincrement())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  amount            Int           // 환불 금액
  reason            String        // 환불 사유
  status            REFUND_STATUS @default(PENDING)
  refundMethod      String?       // 환불 방법 (카드취소, 계좌이체 등)
  processedAt       DateTime?     // 환불 처리 완료 시각
  tossRefundKey     String?       // 토스페이먼츠 환불 키
  paymentId         BigInt        // 원본 결제 ID
  payment           Payment       @relation(fields: [paymentId], references: [id])
  
  @@index([paymentId])
  @@index([status])
  @@index([createdAt])
}

enum ROLE {
  ADMIN
  USER
}

enum USER_STATUS {
  ACTIVE
  INACTIVE
}

enum PROVIDER {
  CREDENTIALS
  KAKAO
  GOOGLE
  APPLE
  NAVER
  GITHUB
  FACEBOOK
}

enum PAYMENT_STATUS {
  COMPLETED @map("결제완료")
  CANCELED  @map("결제취소")
  PARTIAL_REFUNDED @map("부분환불")
  REFUNDED  @map("환불완료")
  REFUNDING @map("환불진행중")
  FAILED    @map("결제실패")
}

enum ORDER_STATUS {
  ACCEPT         @map("결제완료")
  INSTRUCT       @map("상품준비중")
  DELIVERING     @map("배송중")
  FINAL_DELIVERY @map("배송완료")
  CANCELED       @map("주문취소")
}

enum FEEDBACK_REQUEST_STATUS {
  REQUESTED   // 신청됨(대기)
  APPROVED    // 어드민 승인(피드백 제공 준비)
  REJECTED    // 어드민 거절
  COMPLETED   // 피드백 제공 완료(Feedback와 연결)
}

enum REFUND_STATUS {
  PENDING     @map("환불대기")
  PROCESSING  @map("환불처리중")
  COMPLETED   @map("환불완료")
  FAILED      @map("환불실패")
  CANCELED    @map("환불취소")
}

enum PRODUCT_IMAGE_TYPE {
  REPRESENTATIVE
  DETAIL
}