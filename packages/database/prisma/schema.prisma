generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                 @id @default(uuid())
  createdAt                   DateTime               @default(now())
  name                        String                 @default("")
  nickname                    String                 @unique @default("")
  role                        ROLE                   @default(STUDENT)
  status                      USER_STATUS            @default(UNKNOWN)
  bizName                     String                 @default("")
  bizNumber                   String                 @default("")
  expiredAt                   DateTime               @default(now())
  lastLoginAt                 DateTime               @default(now())
  lastPaidAt                  DateTime               @default(now())
  maxProductCount             Int                    @default(200)
  maxUploadProductCount       Int                    @default(0)
  memo                        String                 @default("")
  points                      Int                    @default(0)
  remainingProductCount       Int                    @default(200)
  remainingUploadProductCount Int                    @default(0)
  email                       String?                @unique
  emailVerified               Boolean                @default(false)
  image                       String?
  updatedAt                   DateTime               @default(now()) @updatedAt
  phoneNumber                 String?

  accounts                    Account[]
  sessions                    Session[]
  posts                       Post[] @relation("AuthoredPosts")
  postLikes                   PostLike[]
  comments                    Comment[]
  payments                    Payment[]

  cohortId                    BigInt?
  cohort                      Cohort?                @relation(fields: [cohortId], references: [id])

  @@index([email])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  refreshToken          String?
  accessToken           String?
  scope                 String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accessTokenExpiresAt  DateTime?
  password              String?
  providerId            String
  refreshTokenExpiresAt DateTime?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Cohort {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String   @default("")
  slug      String   @unique
  misc      Json     @default("{}")

  users User[]
}

model Board {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String   @default("")
  slug      String   @unique
  misc      Json     @default("{}")

  posts Post[]
}

model Post {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  thumbnail String   @default("")
  title     String   @default("")
  content   String   @default("")
  slug      String   @unique @default("")
  views     Int      @default(0)
  tags      String[] @default([])
  files     Json     @default("[]")
  authorId  String
  boardId   BigInt
  misc      Json     @default("{}")

  comments Comment[]
  author   User      @relation("AuthoredPosts", fields: [authorId], references: [id])
  board    Board     @relation(fields: [boardId], references: [id])
  likes    PostLike[]

  @@index([authorId])
  @@index([boardId])
}

model PostLike {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postId BigInt
  userId String
  post   Post   @relation(fields: [postId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model Comment {
  id             BigInt    @id @default(autoincrement())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  content        String    @default("")
  authorId       String
  postId         BigInt
  parentId       BigInt?
  deleted        Boolean   @default(false)
  deletedContent String    @default("삭제된 댓글입니다.")
  misc           Json      @default("{}")
  author         User      @relation(fields: [authorId], references: [id])
  parent         Comment?  @relation("CommentParent", fields: [parentId], references: [id])
  replies        Comment[] @relation("CommentParent")
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([postId])
  @@index([parentId])
}

model Log {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  content   Json     @default("{}")
}

model Payment {
  id           BigInt         @id @default(autoincrement())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  amount       Int
  status       PAYMENT_STATUS
  method       String
  isRefunded   Boolean        @default(false)
  refundedAt   DateTime?
  refundAmount Int?
  refundReason String?
  merchantUid  String?        @unique
  pgProvider   String?
  receiptUrl   String?
  paymentKey   String?        @unique
  isTest       Boolean        @default(false)
  orderName    String         @default("서비스 이용료") // 주문명
  description  String?        // 결제 설명
  userId       String
  user    User     @relation(fields: [userId], references: [id])
  refunds Refund[]

  @@index([userId])
  @@index([merchantUid])
  @@index([paymentKey])
}

model PaymentSession {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  expiresAt DateTime
  orderId   String   @unique
  amount    Int
  orderName String
  userId    BigInt?
  status    String   @default("PENDING")

  @@index([orderId])
  @@index([expiresAt])
  @@index([userId])
}

model Refund {
  id            BigInt        @id @default(autoincrement())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  amount        Int           // 환불 금액
  reason        String        // 환불 사유
  status        REFUND_STATUS @default(PENDING)
  refundMethod  String?       // 환불 방법 (카드취소, 계좌이체 등)
  processedAt   DateTime?     // 환불 처리 완료 시각
  tossRefundKey String?       // 토스페이먼츠 환불 키
  paymentId     BigInt        // 원본 결제 ID
  payment       Payment       @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([status])
  @@index([createdAt])
}

enum ROLE {
  SUPER_ADMIN
  ADMIN
  STUDENT
}

enum USER_STATUS {
  UNKNOWN
  PENDING
  ACTIVE
  INACTIVE
}

enum PROVIDER {
  CREDENTIALS
  KAKAO
  GOOGLE
  APPLE
  NAVER
  GITHUB
  FACEBOOK
}

enum PAYMENT_STATUS {
  COMPLETED        @map("결제완료")
  CANCELED         @map("결제취소")
  PARTIAL_REFUNDED @map("부분환불")
  REFUNDED         @map("환불완료")
  REFUNDING        @map("환불진행중")
  FAILED           @map("결제실패")
}

enum REFUND_STATUS {
  PENDING    @map("환불대기")
  PROCESSING @map("환불처리중")
  COMPLETED  @map("환불완료")
  FAILED     @map("환불실패")
  CANCELED   @map("환불취소")
}

model Product {
  id            BigInt   @id @default(autoincrement())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  name          String   // 제품명
  description   String   @default("") // 제품 설명
  price         Int      // 판매가격 (원)
  originalPrice Int?     // 원가 (할인 표시용)
  
  images        Json     @default("[]") // 이미지 URL 배열
  category      String   @default("일반") // 카테고리
  
  inStock       Boolean  @default(true) // 재고 여부
  featured      Boolean  @default(false) // 추천 제품 여부
  
  specifications Json    @default("{}") // 제품 규격 (JSON)
  tags          String[] @default([]) // 태그 배열
  
  viewCount     Int      @default(0) // 조회수
  
  @@index([category])
  @@index([featured])
  @@index([inStock])
}