generator client {
  provider        = "prisma-client"
  output          = "../generated/client"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model AIAssistantSession {
  id                          String   @id
  userId                      String
  conversationId              String
  title                       String?
  titleMessage                String?
  titleResponses              Json?
  selectedTitle               String?
  selectedTitleIndex          Int?
  thumbnailGuideResponses     Json?
  selectedThumbnailGuideIndex Int?
  thumbnailUrls               String?
  scriptResponses             Json?
  metadataResponses           Json?
  shortsTitlesResponses       Json?
  step                        String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime
  User                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@index([step])
  @@index([userId])
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  refreshToken          String?
  accessToken           String?
  scope                 String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  accessTokenExpiresAt  DateTime?
  password              String?
  providerId            String
  refreshTokenExpiresAt DateTime?
  User                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Board {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime
  title     String   @default("")
  slug      String   @unique
  misc      Json     @default("{}")
  Post      Post[]
}

model Class {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime
  title     String   @default("")
  slug      String   @unique
  misc      Json     @default("{}")
  Cohort    Cohort[]

  @@index([slug])
}

model Cohort {
  id          BigInt    @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  title       String    @default("")
  totalWeek   Int       @default(0)
  startDate   DateTime
  endDate     DateTime
  cohortOrder Int       @default(0)
  slug        String    @unique
  misc        Json      @default("{}")
  classId     BigInt
  Class       Class     @relation(fields: [classId], references: [id])
  Mission     Mission[]
  User        User[]

  @@index([slug])
}

model Comment {
  id             BigInt    @id @default(autoincrement())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  content        String    @default("")
  authorId       String
  postId         BigInt
  parentId       BigInt?
  deleted        Boolean   @default(false)
  deletedContent String    @default("삭제된 댓글입니다.")
  misc           Json      @default("{}")
  User           User      @relation(fields: [authorId], references: [id])
  Comment        Comment?  @relation("CommentToComment", fields: [parentId], references: [id])
  other_Comment  Comment[] @relation("CommentToComment")
  Post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([parentId])
  @@index([postId])
}

model CronState {
  id             String    @id
  name           String    @unique
  currentOffset  Int       @default(0)
  batchSize      Int       @default(200)
  totalProcessed Int       @default(0)
  lastRunAt      DateTime?
  lastRunStatus  String?
  lastRunError   String?
  lastBanned     DateTime?
  updatedAt      DateTime
  createdAt      DateTime  @default(now())

  @@index([name])
}

model Log {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  content   Json     @default("{}")
}

model Mission {
  id              BigInt       @id @default(autoincrement())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime
  title           String       @default("")
  description     String       @default("")
  dueDate         DateTime
  misc            Json         @default("{}")
  week            Int          @default(0)
  youtubeUrl      String?
  youtubeVideoId  String?
  autoPersonalize Boolean      @default(false)
  cohortId        BigInt
  Cohort          Cohort       @relation(fields: [cohortId], references: [id])
  Submission      Submission[]
}

model Order {
  id           BigInt       @id @default(autoincrement())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  amount       Int
  status       ORDER_STATUS
  method       String
  isRefunded   Boolean      @default(false)
  refundedAt   DateTime?
  refundAmount Int?
  refundReason String?
  merchantUid  String?      @unique
  pgProvider   String?
  receiptUrl   String?
  paymentKey   String?      @unique
  isTest       Boolean      @default(false)
  orderName    String       @default("서비스 이용료")
  description  String?
  userId       String
  User         User         @relation(fields: [userId], references: [id])
  Refund       Refund[]

  @@index([merchantUid])
  @@index([paymentKey])
  @@index([userId])
}

model PaymentSession {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  expiresAt DateTime
  orderId   String   @unique
  amount    Int
  orderName String
  userId    BigInt?
  status    String   @default("PENDING")

  @@index([expiresAt])
  @@index([orderId])
  @@index([userId])
}

model PointOrder {
  id          BigInt       @id @default(autoincrement())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  amount      Int
  status      ORDER_STATUS
  orderName   String       @default("")
  description String?
  email       String       @default("")
  name        String       @default("")
  calendar    CALENDAR
  birthYear   Int
  birthMonth  Int
  birthDay    Int
  birthHour   Int
  birthMinute Int
  gender      GENDER
  userId      String
  productId   BigInt
  Product     Product      @relation(fields: [productId], references: [id])
  User        User         @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Post {
  id        BigInt     @id @default(autoincrement())
  createdAt DateTime   @default(now())
  updatedAt DateTime
  thumbnail String     @default("")
  title     String     @default("")
  content   String     @default("")
  slug      String     @unique @default("")
  views     Int        @default(0)
  tags      String[]   @default([])
  files     Json       @default("[]")
  authorId  String
  boardId   BigInt
  misc      Json       @default("{}")
  Comment   Comment[]
  User      User       @relation(fields: [authorId], references: [id])
  Board     Board      @relation(fields: [boardId], references: [id])
  PostLike  PostLike[]

  @@index([authorId])
  @@index([boardId])
}

model PostLike {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime
  postId    BigInt
  userId    String
  Post      Post     @relation(fields: [postId], references: [id])
  User      User     @relation(fields: [userId], references: [id])
}

model Product {
  id             BigInt       @id @default(autoincrement())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  icon           String       @default("")
  name           String
  description    String       @default("")
  price          Int
  originalPrice  Int?
  images         Json         @default("[]")
  category       String       @default("일반")
  inStock        Boolean      @default(true)
  featured       Boolean      @default(false)
  specifications Json         @default("{}")
  tags           String[]     @default([])
  viewCount      Int          @default(0)
  PointOrder     PointOrder[]

  @@index([category])
  @@index([featured])
  @@index([inStock])
}

model Refund {
  id            BigInt        @id @default(autoincrement())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  amount        Int
  reason        String
  status        REFUND_STATUS @default(PENDING)
  refundMethod  String?
  processedAt   DateTime?
  tossRefundKey String?
  orderId       BigInt
  Order         Order         @relation(fields: [orderId], references: [id])

  @@index([createdAt])
  @@index([orderId])
  @@index([status])
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Submission {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime
  content   String   @default("")
  misc      Json     @default("{}")
  missionId BigInt
  userId    String
  Mission   Mission  @relation(fields: [missionId], references: [id])
  User      User     @relation(fields: [userId], references: [id])

  @@index([missionId])
  @@index([userId])
}

model User {
  id                          String               @id
  createdAt                   DateTime             @default(now())
  name                        String               @default("")
  nickname                    String               @unique @default("")
  role                        ROLE                 @default(STUDENT)
  status                      USER_STATUS          @default(UNKNOWN)
  bizName                     String               @default("")
  bizNumber                   String               @default("")
  expiredAt                   DateTime             @default(now())
  lastLoginAt                 DateTime             @default(now())
  lastPaidAt                  DateTime             @default(now())
  maxProductCount             Int                  @default(200)
  maxUploadProductCount       Int                  @default(0)
  memo                        String               @default("")
  points                      Int                  @default(0)
  remainingProductCount       Int                  @default(200)
  remainingUploadProductCount Int                  @default(0)
  email                       String?              @unique
  emailVerified               Boolean              @default(false)
  image                       String?
  updatedAt                   DateTime             @default(now())
  phoneNumber                 String?
  learningLevel               String?
  learningGoals               String?
  learningHistory             Json?                @default("{}")
  misc                        Json                 @default("{}")
  cohortId                    BigInt?
  AIAssistantSession          AIAssistantSession[]
  Account                     Account[]
  Comment                     Comment[]
  Order                       Order[]
  PointOrder                  PointOrder[]
  Post                        Post[]
  PostLike                    PostLike[]
  Session                     Session[]
  Submission                  Submission[]
  Cohort                      Cohort?              @relation(fields: [cohortId], references: [id])

  @@index([email])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([identifier])
}

enum CALENDAR {
  SOLAR
  LUNAR
}

enum GENDER {
  MALE
  FEMALE
}

enum ORDER_STATUS {
  PENDING          @map("결제대기")
  PAID             @map("결제완료")
  DELIVERED        @map("전송완료")
  CANCELED         @map("결제취소")
  PARTIAL_REFUNDED @map("부분환불")
  REFUNDED         @map("환불완료")
  REFUNDING        @map("환불진행중")
  FAILED           @map("결제실패")
}

enum PROVIDER {
  CREDENTIALS
  KAKAO
  GOOGLE
  APPLE
  NAVER
  GITHUB
  FACEBOOK
}

enum REFUND_STATUS {
  PENDING    @map("환불대기")
  PROCESSING @map("환불처리중")
  COMPLETED  @map("환불완료")
  FAILED     @map("환불실패")
  CANCELED   @map("환불취소")
}

enum ROLE {
  SUPER_ADMIN
  ADMIN
  STUDENT
  USER
}

enum USER_STATUS {
  UNKNOWN
  PENDING
  ACTIVE
  INACTIVE
}
