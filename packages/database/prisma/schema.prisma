generator client {
  provider        = "prisma-client"
  output          = "../generated/client"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                          String      @id @default(uuid())
  createdAt                   DateTime    @default(now())
  name                        String      @default("")
  nickname                    String      @default("")
  role                        ROLE        @default(USER)
  status                      USER_STATUS @default(ACTIVE)
  expiredAt                   DateTime    @default(now())
  lastLoginAt                 DateTime    @default(now())
  lastPaidAt                  DateTime    @default(now())
  memo                        String      @default("")
  email                       String?     @unique
  emailVerified               Boolean     @default(false)
  image                       String?
  updatedAt                   DateTime    @default(now()) @updatedAt
  phoneNumber                 String?

  misc Json @default("{}")

  accounts    Account[]
  sessions    Session[]
  posts       Post[]       @relation("AuthoredPosts")
  postLikes   PostLike[]
  comments    Comment[]
  orders      Order[]
  reviews     Review[]

  @@index([email])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  refreshToken          String?
  accessToken           String?
  scope                 String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accessTokenExpiresAt  DateTime?
  password              String?
  providerId            String
  refreshTokenExpiresAt DateTime?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Board {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String   @default("")
  slug      String   @unique
  misc      Json     @default("{}")

  posts Post[]
}

model Post {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  thumbnail String   @default("")
  title     String   @default("")
  content   String   @default("")
  slug      String   @unique @default("")
  views     Int      @default(0)
  tags      String[] @default([])
  files     Json     @default("[]")
  authorId  String
  boardId   BigInt
  misc      Json     @default("{}")

  comments Comment[]
  author   User       @relation("AuthoredPosts", fields: [authorId], references: [id])
  board    Board      @relation(fields: [boardId], references: [id])
  likes    PostLike[]

  @@index([authorId])
  @@index([boardId])
}

model PostLike {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postId BigInt
  userId String
  post   Post   @relation(fields: [postId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model Comment {
  id             BigInt    @id @default(autoincrement())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  content        String    @default("")
  authorId       String
  postId         BigInt
  parentId       BigInt?
  deleted        Boolean   @default(false)
  deletedContent String    @default("삭제된 댓글입니다.")
  misc           Json      @default("{}")
  author         User      @relation(fields: [authorId], references: [id])
  parent         Comment?  @relation("CommentParent", fields: [parentId], references: [id])
  replies        Comment[] @relation("CommentParent")
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([postId])
  @@index([parentId])
}

model Log {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  content   Json     @default("{}")
}

model Order {
  id           BigInt       @id @default(autoincrement())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  amount       Int
  status       ORDER_STATUS
  method       String
  isRefunded   Boolean      @default(false)
  refundedAt   DateTime?
  refundAmount Int?
  refundReason String?
  merchantUid  String?      @unique
  pgProvider   String?
  receiptUrl   String?
  paymentKey   String?      @unique
  isTest       Boolean      @default(false)
  orderName    String       @default("서비스 이용료") // 주문명
  description  String? // 결제 설명
  userId       String?
  user         User?        @relation(fields: [userId], references: [id])
  refunds      Refund[]
  review       Review?

  @@index([userId])
  @@index([merchantUid])
  @@index([paymentKey])
}

model PaymentSession {
  id         BigInt   @id @default(autoincrement())
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  orderId    String   @unique
  amount     Int
  orderName  String
  userId     BigInt?
  status     String   @default("PENDING")
  paymentKey String?  // 토스 confirm 후 저장 (추적용)
  guestInfo  Json?    // 비로그인 사용자 정보 저장
  env        String   @default("test") // test or live

  @@index([orderId])
  @@index([expiresAt])
  @@index([userId])
  @@index([paymentKey])
  @@index([status])
}

model Refund {
  id            BigInt        @id @default(autoincrement())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  amount        Int // 환불 금액
  reason        String // 환불 사유
  status        REFUND_STATUS @default(PENDING)
  refundMethod  String? // 환불 방법 (카드취소, 계좌이체 등)
  processedAt   DateTime? // 환불 처리 완료 시각
  tossRefundKey String? // 토스페이먼츠 환불 키
  orderId       BigInt // 원본 주문 ID
  order         Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

enum ROLE {
  SUPER_ADMIN
  ADMIN
  STUDENT
  USER
}

enum GENDER {
  MALE
  FEMALE
}

enum CALENDAR {
  SOLAR
  LUNAR
}

enum USER_STATUS {
  UNKNOWN
  PENDING
  ACTIVE
  INACTIVE
}

enum PROVIDER {
  CREDENTIALS
  KAKAO
  GOOGLE
  APPLE
  NAVER
  GITHUB
  FACEBOOK
}

enum ORDER_STATUS {
  PENDING          @map("결제대기")
  PAID             @map("결제완료")
  DELIVERED        @map("전송완료")
  CANCELED         @map("결제취소")
  PARTIAL_REFUNDED @map("부분환불")
  REFUNDED         @map("환불완료")
  REFUNDING        @map("환불진행중")
  FAILED           @map("결제실패")
}

enum REFUND_STATUS {
  PENDING    @map("환불대기")
  PROCESSING @map("환불처리중")
  COMPLETED  @map("환불완료")
  FAILED     @map("환불실패")
  CANCELED   @map("환불취소")
}

model Product {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  icon          String @default("") // 아이콘
  name          String // 제품명
  description   String @default("") // 제품 설명
  price         Int // 판매가격 (원)
  originalPrice Int? // 원가 (할인 표시용)

  images   Json   @default("[]") // 이미지 URL 배열
  category String @default("일반") // 카테고리

  inStock  Boolean @default(true) // 재고 여부
  featured Boolean @default(false) // 추천 제품 여부

  specifications Json     @default("{}") // 제품 규격 (JSON)
  tags           String[] @default([]) // 태그 배열

  viewCount Int @default(0) // 조회수

  @@index([category])
  @@index([featured])
  @@index([inStock])
}

model Review {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  rating    Int      @default(5) // 별점
  nickname  String   @default("") // 닉네임
  content   String   @default("") // 리뷰 내용

  isPublished Boolean @default(true)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  orderId   BigInt?  @unique
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  
  @@index([userId])
}

