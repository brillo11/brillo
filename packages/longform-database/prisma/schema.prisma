generator client {
  provider        = "prisma-client"
  output          = "../generated/client"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model YoutubeChannel {
  id              String    @id // YouTube Channel ID (UC...)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  title           String    @default("")
  thumbnailUrl    String    @default("")
  regionCode      String? // 수집 기준 지역 (예: KR)
  uploadsPlaylist String? // 업로드 플레이리스트 ID
  videoCount      Int? // 채널의 전체 영상 개수
  subscriberCount Int? // 채널 구독자 수
  overallAvgView  Float? // 전체 평균 조회수 (totalViews / videoCount)
  recentAvgVph    Float? // 최근 N개 평균 VPH
  lastCrawledAt   DateTime?
  misc            Json      @default("{}")

  videos YoutubeVideo[]
  shorts YoutubeShorts[]
}

model YoutubeVideo {
  id                String                 @id // YouTube Video ID
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  channelId         String
  title             String                 @default("")
  description       String                 @default("")
  thumbnailUrl      String                 @default("")
  publishedAt       DateTime?
  duration          String                 @default("")
  viewCount         Int                    @default(0)
  likeCount         Int?
  commentCount      Int?
  viewsPerHour      Float?
  outlierVph        Float?
  outlierView       Float?
  outlierSubscriber Float?
  regionCode        String? // 수집 지역 코드
  categoryId        Int? // YouTube 비디오 카테고리 ID
  crawledAt         DateTime               @default(now())
  misc              Json                   @default("{}")
  searchVector      Unsupported("vector")?

  channel YoutubeChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([regionCode])
  @@index([outlierVph])
  @@index([viewsPerHour])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([searchVector], map: "youtube_video_search_vector_embedding_hnsw")
}

model YoutubeShorts {
  id                String    @id // YouTube Video ID
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  channelId         String
  title             String    @default("")
  description       String    @default("")
  thumbnailUrl      String    @default("")
  publishedAt       DateTime?
  duration          String    @default("")
  viewCount         Int       @default(0)
  likeCount         Int?
  commentCount      Int?
  viewsPerHour      Float?
  outlierVph        Float?
  outlierView       Float?
  outlierSubscriber Float?
  regionCode        String? // 수집 지역 코드
  categoryId        Int? // YouTube 비디오 카테고리 ID
  crawledAt         DateTime  @default(now())
  misc              Json      @default("{}")
  searchVector      Unsupported("vector")?

  channel YoutubeChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([regionCode])
  @@index([outlierVph])
  @@index([viewsPerHour])
  @@index([publishedAt])
  @@index([categoryId])
  @@index([searchVector], map: "youtube_short_search_vector_embedding_hnsw")
}
