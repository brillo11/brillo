{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^generate"],
      "env": [
        "DATABASE_URL",
        "DIRECT_URL",
        "TOSS_SECRET_KEY",
        "KAKAO_CLIENT_ID",
        "KAKAO_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "BETTER_AUTH_SECRET",
        "NHN_SMS_URL",
        "NHN_SMS_APP_KEY",
        "NHN_SMS_SECRET_KEY",
        "NHN_SMS_SEND_NO",
        "NHN_SMS_ADMIN_RECIPIENT"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "db:migrate:dev": {
      "cache": false,
      "persistent": true
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "generate": {
      "cache": false,
      "dependsOn": ["^generate"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
